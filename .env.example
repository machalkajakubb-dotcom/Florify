# ================================================================
# FLORIFY – Konfigurační soubor
# ZKOPÍRUJTE TENTO SOUBOR jako .env.local a vyplňte hodnoty
# ================================================================

# ─── SUPABASE ───────────────────────────────────────────────────
# Kde je najdete: supabase.com → váš projekt → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# POZOR: tento klíč NIKDY nesmí mít prefix NEXT_PUBLIC_ (musí zůstat jen na serveru).
# Najdete ho v Supabase → Settings → API → "service_role" (secret).
# Používá se výhradně pro trvalé smazání účtu (GDPR "právo být zapomenut").
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OPENWEATHERMAP ─────────────────────────────────────────────
# Kde je najdete: openweathermap.org → My API Keys (po registraci zdarma)
NEXT_PUBLIC_OPENWEATHER_API_KEY=YOUR_KEY_HERE

# ─── GOOGLE GEMINI (Flora AI chat) ──────────────────────────────
# Kde ho najdete: aistudio.google.com → Get API key
GEMINI_API_KEY=AIzaSy...
